{
  "description": "myfi harness hooks -- closed-flock dispatch guard, dedup gate, venv persistence, and the IMPROVE loop's mechanized harvest step. Ported from shepherd's hooks/ (~/src/fl03/shepherd/hooks/), trimmed to what myfi's flatter single-tier flock needs (no teammate/conductor/lane tiering).",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session_venv.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/dispatch_guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/dedup_write_guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/adaptation_capture.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
